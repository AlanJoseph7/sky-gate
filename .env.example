# SkyGate Environment Variables
# Copy this file to .env and fill in your values.

# ── JWT Secret (REQUIRED in production) ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SKYGATE_SECRET_KEY=

# ── OpenSky Network Credentials (optional) ───────────────────────────────────
# Sign up at https://opensky-network.org/
# Anonymous access is limited to 400 requests/day.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── CORS Origins (optional) ──────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to localhost.
# SKYGATE_CORS_ORIGINS=http://localhost:5000,https://your-domain.com

# ── Rate Limiting (optional) ──────────────────────────────────────────────────
# SKYGATE_RATE_LIMIT_LOGIN=10/minute
# SKYGATE_RATE_LIMIT_SIGNUP=5/minute

# ── Server (optional) ────────────────────────────────────────────────────────
# SKYGATE_HOST=0.0.0.0
# SKYGATE_PORT=5000
# SKYGATE_MAX_LOG=200
# SKYGATE_JWT_EXPIRE_MINUTES=1440

# ── adsb.lol API (optional) ──────────────────────────────────────────────────
# ADSBLOL_API_BASE=https://api.adsb.lol
# ADSBLOL_API_PATH=/v2/point/20.5/82.5/250
# ADSBLOL_API_KEY=
